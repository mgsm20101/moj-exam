<?xml version="1.0" encoding="utf-8"?>
<!--
Web Deploy profile for MonsterASP. Connection details (URL/site/username/password) are
NOT stored here — they are injected at publish time via /p: MSBuild properties from
GitHub Actions secrets (see .github/workflows/deploy-monster.yml).

The skip rules below stop Web Deploy's sync from deleting wwwroot/question-images on the
server, since that folder holds question images uploaded by admins at runtime and is not
part of the build output — without these rules every deploy would wipe it out.
-->
<Project>
  <PropertyGroup>
    <WebPublishMethod>MSDeploy</WebPublishMethod>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <LaunchSiteAfterPublish>false</LaunchSiteAfterPublish>
    <ExcludeApp_Data>false</ExcludeApp_Data>
    <SkipExtraFilesOnServer>false</SkipExtraFilesOnServer>
    <MSDeployPublishMethod>WMSVC</MSDeployPublishMethod>
    <EnableMSDeployAppOffline>true</EnableMSDeployAppOffline>
    <AllowUntrustedCertificate>true</AllowUntrustedCertificate>
    <_SavePWD>false</_SavePWD>
  </PropertyGroup>
  <ItemGroup>
    <MsDeploySkipRules Include="SkipDeleteQuestionImagesFiles">
      <SkipAction>Delete</SkipAction>
      <ObjectName>filePath</ObjectName>
      <AbsolutePath>wwwroot\\question-images\\.*</AbsolutePath>
    </MsDeploySkipRules>
    <MsDeploySkipRules Include="SkipDeleteQuestionImagesDir">
      <SkipAction>Delete</SkipAction>
      <ObjectName>dirPath</ObjectName>
      <AbsolutePath>wwwroot\\question-images(\\.*)?</AbsolutePath>
    </MsDeploySkipRules>
  </ItemGroup>
</Project>
